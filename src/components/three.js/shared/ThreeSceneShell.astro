---
const {
  id,
  lowPowerControlId = "",
  antialiasControlId = "",
  ...wrapperProps
} = Astro.props;
---

<div class="viz-container" id={id}>
  <div
    class="threejs-viz"
    data-low-power-control-id={lowPowerControlId}
    data-antialias-control-id={antialiasControlId}
    {...wrapperProps}
  >
    <slot />
  </div>
</div>

<style>
  .threejs-viz {
    width: 100%;
    aspect-ratio: 1 / 1;
    max-width: 720px;
    min-height: 320px;
    margin: 0 auto;
    border-radius: 8px;
    overflow: hidden;
    background: #e0e0e0;
  }

  .threejs-viz :global(canvas) {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
