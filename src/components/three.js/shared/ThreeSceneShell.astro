---
import WidgetContainer from "../../WidgetContainer.astro";

const {
  id,
  pixelRatioCapControlId = "",
  antialiasControlId = "",
  ...wrapperProps
} = Astro.props;
---

<WidgetContainer id={id} sceneClass="threejs-viz-shell" background="#e0e0e0">
  <div
    class="threejs-viz"
    data-pixel-ratio-cap-control-id={pixelRatioCapControlId}
    data-antialias-control-id={antialiasControlId}
    {...wrapperProps}
  >
    <slot />
  </div>
</WidgetContainer>

<style>
  .threejs-viz-shell {
    padding: 0;
  }

  .threejs-viz {
    width: 100%;
    height: 100%;
    background: transparent;
  }

  .threejs-viz :global(canvas) {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
