---
const lowPowerControlId = Astro.props.lowPowerControlId ?? "";
const antialiasControlId = Astro.props.antialiasControlId ?? "";
---

<div class="viz-container" id="three-points-not-collinear-wrapper">
  <div
    class="threejs-viz"
    data-low-power-control-id={lowPowerControlId}
    data-antialias-control-id={antialiasControlId}
  ></div>
</div>

<style>
  .threejs-viz {
    width: 100%;
    aspect-ratio: 1 / 1;
    max-width: 720px;
    min-height: 320px;
    margin: 0 auto;
    border-radius: 8px;
    overflow: hidden;
    background: #e0e0e0;
  }
  .threejs-viz :global(canvas) {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  import * as THREE from "three";
import {
addReferencePlane,
mountManagedThreeScene,
} from "./functions/three";

  const wrapper = document.querySelector(
    "#three-points-not-collinear-wrapper .threejs-viz",
  );
  if (wrapper instanceof HTMLDivElement) {
    mountManagedThreeScene(wrapper, {
      cameraPosition: [5, 4.5, 5],
      cameraLookAt: [0, 0, 0],
      setup: ({ scene }) => {
        addReferencePlane(scene);

      const points = [
        new THREE.Vector3(-1.5, 0, -0.8),
        new THREE.Vector3(1.2, 0, -0.4),
        new THREE.Vector3(0.2, 0, 1.5),
      ];
      const markerGeometry = new THREE.SphereGeometry(0.06, 12, 8);
      const markerMaterial = new THREE.MeshBasicMaterial({ color: 0xdc2626 });
      for (const p of points) {
        const marker = new THREE.Mesh(markerGeometry, markerMaterial);
        marker.position.copy(p);
        scene.add(marker);
      }

        return undefined;
      },
    });
  }
</script>
