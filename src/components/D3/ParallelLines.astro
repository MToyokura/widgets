---
const lowPowerControlId = Astro.props.lowPowerControlId ?? "";
const antialiasControlId = Astro.props.antialiasControlId ?? "";
---

<div class="viz-container" id="parallel-lines-wrapper">
  <div
    class="threejs-viz"
    data-low-power-control-id={lowPowerControlId}
    data-antialias-control-id={antialiasControlId}
  ></div>
</div>

<style>
  .threejs-viz {
    width: 100%;
    aspect-ratio: 1 / 1;
    max-width: 720px;
    min-height: 320px;
    margin: 0 auto;
    border-radius: 8px;
    overflow: hidden;
    background: #e0e0e0;
  }

  .threejs-viz :global(canvas) {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  import * as THREE from "three";
import { OrbitControls } from "three/addons/controls/OrbitControls.js";
import { Line2 } from "three/addons/lines/Line2.js";
import { LineGeometry } from "three/addons/lines/LineGeometry.js";
import { LineMaterial } from "three/addons/lines/LineMaterial.js";
import {
createLowPowerRenderer,
disposeRenderer,
disposeSceneResources,
initializeThreeScene,
observeAntialiasPreference,
observeLowPowerPreference,
observeWrapperSize,
setRendererPerformanceMode,
} from "./functions/three";

  const wrapper = document.querySelector(
    "#parallel-lines-wrapper .threejs-viz",
  );

  if (wrapper instanceof HTMLDivElement) {
    let sceneHandle: ReturnType<typeof initializeThreeScene> | undefined;

    const mountScene = () => {
      const lowPowerControlId = wrapper.dataset.lowPowerControlId || "";
      const antialiasControlId = wrapper.dataset.antialiasControlId || "";

      const scene = new THREE.Scene();
      scene.background = new THREE.Color(0xe0e0e0);

      const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100);
      camera.position.set(3.5, 3.5, 7.2);
      camera.lookAt(0, 1.6, 0);

      const renderer = createLowPowerRenderer(
        wrapper,
        lowPowerControlId,
        antialiasControlId,
      );

      const controls = new OrbitControls(camera, renderer.domElement);
      const resolution = new THREE.Vector2(1, 1);

      const plane = new THREE.Mesh(
        new THREE.PlaneGeometry(4.4, 4.4),
        new THREE.MeshBasicMaterial({
          color: 0xf8fafc,
          side: THREE.DoubleSide,
          transparent: true,
          opacity: 0.5,
        }),
      );
      plane.rotation.x = -Math.PI / 2;
      scene.add(plane);
      scene.add(new THREE.GridHelper(4.4, 8, 0x94a3b8, 0xcbd5e1));

      const direction = new THREE.Vector3(1.9, 0.8, 0.9).normalize();
      const halfLength = 1.85;
      const offset = direction.clone().multiplyScalar(halfLength);

      const blackCenter = new THREE.Vector3(-0.138, 1.7, -0.45);
      const redCenter = new THREE.Vector3(-0.202, 0.962, 0.559);

      const blackGeometry = new LineGeometry();
      blackGeometry.setPositions([
        -offset.x,
        -offset.y,
        -offset.z,
        offset.x,
        offset.y,
        offset.z,
      ]);

      const redGeometry = new LineGeometry();
      redGeometry.setPositions([
        -offset.x,
        -offset.y,
        -offset.z,
        offset.x,
        offset.y,
        offset.z,
      ]);

      const blackLine = new Line2(
        blackGeometry,
        new LineMaterial({ color: 0x111827, linewidth: 3, resolution }),
      );
      const redLine = new Line2(
        redGeometry,
        new LineMaterial({ color: 0xef4444, linewidth: 3, resolution }),
      );
      const blackGroup = new THREE.Group();
      blackGroup.position.copy(blackCenter);
      blackGroup.add(blackLine);
      const redGroup = new THREE.Group();
      redGroup.position.copy(redCenter);
      redGroup.add(redLine);

      scene.add(blackGroup);
      scene.add(redGroup);
      // --- ADD THIS TO CREATE THE TRANSLUCENT PLANE ---

      // 1. Find the exact center point between the two parallel lines
      const planeMidpoint = new THREE.Vector3()
        .addVectors(blackCenter, redCenter)
        .multiplyScalar(0.5);

      // 2. Mathematically calculate the orientation (Normal/Axes) of the plane
      const xAxis = direction.clone(); // The plane's local X follows the line direction

      // Find a vector pointing from the black line to the red line
      const diff = new THREE.Vector3().subVectors(redCenter, blackCenter);

      // The Z-axis (Normal) is perpendicular to both the direction and the connecting vector
      const zAxis = new THREE.Vector3().crossVectors(xAxis, diff).normalize();

      // The local Y-axis is perpendicular to Z and X, lying perfectly on the plane
      const yAxis = new THREE.Vector3().crossVectors(zAxis, xAxis).normalize();

      // Create a rotation matrix from these 3 aligned axes
      const planeBasis = new THREE.Matrix4().makeBasis(xAxis, yAxis, zAxis);

      // 3. Create the translucent plane mesh
      // Width = 5.0 (longer than the lines), Height = 2.5 (wider than the gap between them)
      const intersectionPlane = new THREE.Mesh(
        new THREE.PlaneGeometry(5.0, 2.5),
        new THREE.MeshBasicMaterial({
          color: 0xffffff,
          side: THREE.DoubleSide,
          transparent: true,
          opacity: 0.2, // See-through
          depthWrite: false, // Prevents rendering glitches with the lines
        }),
      );

      // 4. Apply the computed position and rotation
      intersectionPlane.position.copy(planeMidpoint);
      intersectionPlane.rotation.setFromRotationMatrix(planeBasis);

      scene.add(intersectionPlane);
      // ------------------------------------------------

      function resize(width: number, height: number) {
        camera.aspect = width / height;
        camera.updateProjectionMatrix();
        renderer.setSize(width, height, false);
        blackLine.material.resolution.set(width, height);
        redLine.material.resolution.set(width, height);
        render();
      }

      function render() {
        renderer.render(scene, camera);
      }

      controls.addEventListener("change", render);
      const stopLowPowerObserver = observeLowPowerPreference(
        lowPowerControlId,
        (lowPower) => {
          setRendererPerformanceMode(renderer, lowPower);
          render();
        },
      );
      const stopAntialiasObserver = observeAntialiasPreference(
        antialiasControlId,
        () => {
          sceneHandle?.remount();
        },
      );
      const resizeObserver = observeWrapperSize(wrapper, resize);

      return () => {
        controls.dispose();
        stopLowPowerObserver?.();
        stopAntialiasObserver?.();
        resizeObserver.disconnect();
        disposeSceneResources(scene);
        disposeRenderer(renderer);
      };
    };

    sceneHandle = initializeThreeScene(wrapper, mountScene);
  }
</script>
