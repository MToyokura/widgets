---
import WidgetContainer from "../WidgetContainer.astro";

import {
  getLinePathThroughPoint,
  getPointOnCircle,
  getPolygonPath,
  reflectPointAcrossLine,
} from "./functions/geometry";

const width = 400;
const height = 400;
const lineHandleDistance = 88;
const lineHalfLength = 280;
const initialOriginalPoints = [
  { x: 30, y: 275 },
  { x: 90, y: 135 },
  { x: 175, y: 225 },
];
const initialCentroid = {
  x:
    initialOriginalPoints.reduce((sum, p) => sum + p.x, 0) /
    initialOriginalPoints.length,
  y:
    initialOriginalPoints.reduce((sum, p) => sum + p.y, 0) /
    initialOriginalPoints.length,
};
const initialLinePoint = { x: 200, y: 200 };
const initialLineAngle = -Math.PI / 2;

function getConnectorPath(
  originalPoints: { x: number; y: number }[],
  transformedPoints: { x: number; y: number }[],
) {
  return originalPoints
    .map(
      (point, index) =>
        `M ${point.x} ${point.y} L ${transformedPoints[index].x} ${transformedPoints[index].y}`,
    )
    .join(" ");
}

const initialReflectedPoints = initialOriginalPoints.map((point) =>
  reflectPointAcrossLine(point, initialLinePoint, initialLineAngle),
);
const initialLineHandle = getPointOnCircle(
  initialLinePoint,
  lineHandleDistance,
  initialLineAngle,
);
---

<WidgetContainer id="reflection-wrapper">
  <svg viewBox={`0 0 ${width} ${height}`}>
    {
      Array.from({ length: Math.floor(width / 40) + 1 }, (_, i) => i * 40).map(
        (x) => (
          <line
            x1={x}
            y1="0"
            x2={x}
            y2={height}
            stroke="#d7dde5"
            stroke-width="1"
          />
        ),
      )
    }
    {
      Array.from({ length: Math.floor(height / 40) + 1 }, (_, i) => i * 40).map(
        (y) => (
          <line
            x1="0"
            y1={y}
            x2={width}
            y2={y}
            stroke="#d7dde5"
            stroke-width="1"
          />
        ),
      )
    }
    <path
      id="reflection-connectors"
      d={getConnectorPath(initialOriginalPoints, initialReflectedPoints)}
      fill="none"
      stroke="#94a3b8"
      stroke-width="2"
      stroke-dasharray="5 5"
      style="pointer-events: none;"></path>
    <path
      id="reflection-line"
      d={getLinePathThroughPoint(
        initialLinePoint,
        initialLineAngle,
        lineHalfLength,
      )}
      fill="none"
      stroke="#111827"
      stroke-width="3"
      stroke-linecap="round"
      style="pointer-events: none;"></path>
    <path
      id="reflection-original-shape"
      d={getPolygonPath(initialOriginalPoints)}
      fill="rgba(37, 99, 235, 0.24)"
      stroke="#2563eb"
      stroke-width="3"
      style="pointer-events: none;"></path>
    <path
      id="reflection-transformed-shape"
      d={getPolygonPath(initialReflectedPoints)}
      fill="rgba(22, 163, 74, 0.2)"
      stroke="#16a34a"
      stroke-width="3"
      style="pointer-events: none;"></path>
    <circle
      id="reflection-line-angle-handle"
      cx={initialLineHandle.x}
      cy={initialLineHandle.y}
      r="10"
      fill="#f97316"
      style="cursor: grab; touch-action: none;"></circle>
    <circle
      id="reflection-move-handle"
      cx={initialCentroid.x}
      cy={initialCentroid.y}
      r="8"
      fill="#2563eb"
      style="cursor: grab; touch-action: none;"></circle>
  </svg>
</WidgetContainer>

<script>
  import * as d3 from "d3";
  import {
    getLinePathThroughPoint,
    getPointOnCircle,
    getPolygonPath,
    reflectPointAcrossLine,
  } from "./functions/geometry";

  function getConnectorPath(
    originalPoints: { x: number; y: number }[],
    transformedPoints: { x: number; y: number }[],
  ) {
    return originalPoints
      .map(
        (point, index) =>
          `M ${point.x} ${point.y} L ${transformedPoints[index].x} ${transformedPoints[index].y}`,
      )
      .join(" ");
  }

  function setupInteractivity() {
    const originalShape = d3.select<SVGPathElement, unknown>(
      "#reflection-original-shape",
    );
    const transformedShape = d3.select<SVGPathElement, unknown>(
      "#reflection-transformed-shape",
    );
    const connectors = d3.select<SVGPathElement, unknown>(
      "#reflection-connectors",
    );
    const line = d3.select<SVGPathElement, unknown>("#reflection-line");
    const lineAngleHandle = d3.select<SVGCircleElement, unknown>(
      "#reflection-line-angle-handle",
    );
    const moveHandle = d3.select<SVGCircleElement, unknown>(
      "#reflection-move-handle",
    );

    if (
      originalShape.empty() ||
      transformedShape.empty() ||
      connectors.empty() ||
      line.empty() ||
      lineAngleHandle.empty() ||
      moveHandle.empty()
    ) {
      return;
    }

    const lineHalfLength = 280;
    const lineHandleDistance = 88;
    let originalPoints = [
      { x: 30, y: 275 },
      { x: 90, y: 135 },
      { x: 175, y: 225 },
    ];
    let centroid = {
      x:
        originalPoints.reduce((sum, p) => sum + p.x, 0) / originalPoints.length,
      y:
        originalPoints.reduce((sum, p) => sum + p.y, 0) / originalPoints.length,
    };
    const linePoint = { x: 200, y: 200 };
    let lineAngle = -Math.PI / 2;

    function render() {
      const reflectedPoints = originalPoints.map((point) =>
        reflectPointAcrossLine(point, linePoint, lineAngle),
      );
      const directionHandle = getPointOnCircle(
        linePoint,
        lineHandleDistance,
        lineAngle,
      );

      originalShape.attr("d", getPolygonPath(originalPoints));
      transformedShape.attr("d", getPolygonPath(reflectedPoints));
      connectors.attr("d", getConnectorPath(originalPoints, reflectedPoints));
      line.attr(
        "d",
        getLinePathThroughPoint(linePoint, lineAngle, lineHalfLength),
      );
      lineAngleHandle
        .attr("cx", directionHandle.x)
        .attr("cy", directionHandle.y);
      moveHandle.attr("cx", centroid.x).attr("cy", centroid.y);
    }

    lineAngleHandle.call(
      d3
        .drag<SVGCircleElement, unknown>()
        .on("start", () => {
          lineAngleHandle.style("cursor", "grabbing");
        })
        .on("drag", (event) => {
          lineAngle = Math.atan2(event.y - linePoint.y, event.x - linePoint.x);
          render();
        })
        .on("end", () => {
          lineAngleHandle.style("cursor", "grab");
        }),
    );

    moveHandle.call(
      d3
        .drag<SVGCircleElement, unknown>()
        .on("start", () => {
          moveHandle.style("cursor", "grabbing");
        })
        .on("drag", (event) => {
          const dx = event.x - centroid.x;
          const dy = event.y - centroid.y;
          originalPoints = originalPoints.map((p) => ({
            x: p.x + dx,
            y: p.y + dy,
          }));
          centroid = { x: event.x, y: event.y };
          render();
        })
        .on("end", () => {
          moveHandle.style("cursor", "grab");
        }),
    );

    render();
  }

  setupInteractivity();
  document.addEventListener("astro:after-swap", setupInteractivity);
</script>
