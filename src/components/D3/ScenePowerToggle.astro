---
const {
  id,
  checked = true,
  label = "省電力モード",
  description = "低性能な端末ではオンにすると描画負荷を抑えられます。画質を優先したい場合はオフにしてください。",
} = Astro.props;
---

<div class="scene-power-toggle">
  <label class="scene-power-toggle__label" for={id}>
    <input
      id={id}
      class="scene-power-toggle__input"
      type="checkbox"
      checked={checked}
    />
    <span>{label}</span>
  </label>
  <p class="scene-power-toggle__description">{description}</p>
</div>

<style>
  .scene-power-toggle {
    margin: 0 0 1.5rem;
    padding: 0.875rem 1rem;
    border: 1px solid #cbd5e1;
    border-radius: 0.75rem;
    background: #f8fafc;
  }

  .scene-power-toggle__label {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-weight: 600;
    color: #0f172a;
    cursor: pointer;
  }

  .scene-power-toggle__input {
    inline-size: 1rem;
    block-size: 1rem;
    margin: 0;
  }

  .scene-power-toggle__description {
    margin: 0.5rem 0 0;
    font-size: 0.95rem;
    color: #475569;
  }
</style>
