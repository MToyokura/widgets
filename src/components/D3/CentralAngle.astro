---
import WidgetContainer from "../WidgetContainer.astro";

import {
  getAngleArcPath,
  getAngleDegrees,
  getAngleLabelPosition,
  getCircleArcPath,
  getPointOnCircle,
  getTrianglePath,
} from "./functions/geometry";

const width = 400;
const height = 400;
const radius = 150;
const cx = width / 2;
const cy = height / 2;
const center = { x: cx, y: cy };
const initialAngleA = (3 * Math.PI) / 4;
const initialAngleB = Math.PI / 4;

function getSignedMinorDelta(startAngle: number, endAngle: number) {
  let delta = endAngle - startAngle;

  if (delta <= -Math.PI) delta += Math.PI * 2;
  if (delta > Math.PI) delta -= Math.PI * 2;

  return delta;
}

function getInscribedPoint(angleA: number, angleB: number) {
  const midpointOfMajorArc =
    angleA + getSignedMinorDelta(angleA, angleB) / 2 + Math.PI;

  return getPointOnCircle(center, radius, midpointOfMajorArc);
}

function getInscribedLinesPath(
  a: { x: number; y: number },
  b: { x: number; y: number },
  vertex: { x: number; y: number },
) {
  return `M ${vertex.x} ${vertex.y} L ${a.x} ${a.y} M ${vertex.x} ${vertex.y} L ${b.x} ${b.y}`;
}

const p1 = getPointOnCircle(center, radius, initialAngleA);
const p2 = getPointOnCircle(center, radius, initialAngleB);
const p3 = getInscribedPoint(initialAngleA, initialAngleB);
const initialPath = getTrianglePath(p1, center, p2);
const initialCentralAngleArcPath = getAngleArcPath(p1, center, p2);
const initialCentralAngleLabelPosition = getAngleLabelPosition(p1, center, p2);
const initialCentralAngleDegrees = getAngleDegrees(p1, center, p2);
const initialInscribedAngleArcPath = getAngleArcPath(p1, p3, p2);
const initialInscribedAngleLabelPosition = getAngleLabelPosition(
  p1,
  p3,
  p2,
  36,
);
const initialInscribedAngleDegrees = getAngleDegrees(p1, p3, p2);
const initialHighlightedArcPath = getCircleArcPath(
  center,
  radius,
  initialAngleA,
  initialAngleB,
);
---

<WidgetContainer id="central-angle-wrapper">
  <svg viewBox={`0 0 ${width} ${height}`}>
    <circle
      cx={cx}
      cy={cy}
      r={radius}
      fill="none"
      stroke="#888"
      stroke-width="2"></circle>
    <path
      id="central-angle-highlighted-arc"
      d={initialHighlightedArcPath}
      fill="none"
      stroke="#f59e0b"
      stroke-width="8"
      stroke-linecap="round"
      opacity="0.85"
      style="pointer-events: none;"></path>
    <path
      id="central-angle-sector"
      d={initialPath}
      fill="rgba(52, 152, 219, 0.3)"
      stroke="#3498db"
      stroke-width="3"
      style="pointer-events: none;"></path>
    <path
      id="central-angle-inscribed-lines"
      d={getInscribedLinesPath(p1, p2, p3)}
      fill="none"
      stroke="#16a34a"
      stroke-width="2.5"
      stroke-dasharray="6 4"
      opacity="0.9"
      style="pointer-events: none;"></path>
    <path
      id="central-angle-marker"
      d={initialCentralAngleArcPath}
      fill="none"
      stroke="#1f2937"
      stroke-width="3"
      stroke-linecap="round"
      style="pointer-events: none;"></path>
    <path
      id="central-angle-inscribed-marker"
      d={initialInscribedAngleArcPath}
      fill="none"
      stroke="#15803d"
      stroke-width="3"
      stroke-linecap="round"
      style="pointer-events: none;"></path>
    <text
      id="central-angle-label"
      x={initialCentralAngleLabelPosition.x}
      y={initialCentralAngleLabelPosition.y}
      fill="#111827"
      font-size="16"
      font-weight="700"
      text-anchor="middle"
      dominant-baseline="middle"
      style="pointer-events: none; user-select: none;"
    >
      {`${Math.round(initialCentralAngleDegrees)}°`}
    </text>
    <text
      id="central-angle-inscribed-label"
      x={initialInscribedAngleLabelPosition.x}
      y={initialInscribedAngleLabelPosition.y}
      fill="#15803d"
      font-size="15"
      font-weight="700"
      text-anchor="middle"
      dominant-baseline="middle"
      style="pointer-events: none; user-select: none;"
    >
      {`${Math.round(initialInscribedAngleDegrees)}°`}
    </text>
    <text
      id="central-angle-relation-label"
      x={cx}
      y={height - 18}
      fill="#92400e"
      font-size="14"
      font-weight="700"
      text-anchor="middle"
      style="pointer-events: none; user-select: none;"
    >
      {
        `${Math.round(initialCentralAngleDegrees)}° = 2 x ${Math.round(initialInscribedAngleDegrees)}°`
      }
    </text>
    <circle cx={cx} cy={cy} r={7} fill="#e74c3c"></circle>
    <circle
      id="central-angle-inscribed-point"
      cx={p3.x}
      cy={p3.y}
      r={7}
      fill="#16a34a"
      style="cursor: grab; touch-action: none;"></circle>
    <circle
      id="central-angle-handle-a"
      cx={p1.x}
      cy={p1.y}
      r={10}
      fill="#2563eb"
      style="cursor: grab; touch-action: none;"></circle>
    <circle
      id="central-angle-handle-b"
      cx={p2.x}
      cy={p2.y}
      r={10}
      fill="#2563eb"
      style="cursor: grab; touch-action: none;"></circle>
  </svg>
</WidgetContainer>

<script>
  import * as d3 from "d3";
  import {
    getAngleArcPath,
    getAngleDegrees,
    getAngleLabelPosition,
    getCircleArcPath,
    getPointOnCircle,
    getTrianglePath,
  } from "./functions/geometry";

  function getSignedMinorDelta(startAngle: number, endAngle: number) {
    let delta = endAngle - startAngle;

    if (delta <= -Math.PI) delta += Math.PI * 2;
    if (delta > Math.PI) delta -= Math.PI * 2;

    return delta;
  }

  function getInscribedLinesPath(
    a: { x: number; y: number },
    b: { x: number; y: number },
    vertex: { x: number; y: number },
  ) {
    return `M ${vertex.x} ${vertex.y} L ${a.x} ${a.y} M ${vertex.x} ${vertex.y} L ${b.x} ${b.y}`;
  }

  function setupInteractivity() {
    const handleA = d3.select<SVGCircleElement, unknown>(
      "#central-angle-handle-a",
    );
    const handleB = d3.select<SVGCircleElement, unknown>(
      "#central-angle-handle-b",
    );
    const sector = d3.select<SVGPathElement, unknown>("#central-angle-sector");
    const highlightedArc = d3.select<SVGPathElement, unknown>(
      "#central-angle-highlighted-arc",
    );
    const inscribedLines = d3.select<SVGPathElement, unknown>(
      "#central-angle-inscribed-lines",
    );
    const marker = d3.select<SVGPathElement, unknown>("#central-angle-marker");
    const inscribedMarker = d3.select<SVGPathElement, unknown>(
      "#central-angle-inscribed-marker",
    );
    const inscribedPoint = d3.select<SVGCircleElement, unknown>(
      "#central-angle-inscribed-point",
    );
    const angleLabel = d3.select<SVGTextElement, unknown>(
      "#central-angle-label",
    );
    const inscribedLabel = d3.select<SVGTextElement, unknown>(
      "#central-angle-inscribed-label",
    );
    const relationLabel = d3.select<SVGTextElement, unknown>(
      "#central-angle-relation-label",
    );

    if (
      handleA.empty() ||
      handleB.empty() ||
      sector.empty() ||
      highlightedArc.empty() ||
      inscribedLines.empty() ||
      marker.empty() ||
      inscribedMarker.empty() ||
      inscribedPoint.empty() ||
      angleLabel.empty() ||
      inscribedLabel.empty() ||
      relationLabel.empty()
    ) {
      return;
    }

    const cx = 200;
    const cy = 200;
    const radius = 150;
    const center = { x: cx, y: cy };
    let angleA = (3 * Math.PI) / 4;
    let angleB = Math.PI / 4;
    let angleC = angleA + getSignedMinorDelta(angleA, angleB) / 2 + Math.PI;

    function getPoints() {
      return {
        p1: getPointOnCircle(center, radius, angleA),
        p2: getPointOnCircle(center, radius, angleB),
        p3: getPointOnCircle(center, radius, angleC),
      };
    }

    function formatAngle(angleDegrees: number) {
      const roundedAngle = Math.round(angleDegrees * 10) / 10;

      return Number.isInteger(roundedAngle)
        ? `${roundedAngle.toFixed(0)}°`
        : `${roundedAngle.toFixed(1)}°`;
    }

    function normalizeAngle(angle: number) {
      const fullTurn = Math.PI * 2;
      return ((angle % fullTurn) + fullTurn) % fullTurn;
    }

    function ensurePointInMajorArc() {
      const delta = getSignedMinorDelta(angleA, angleB);
      const majorStart = delta > 0 ? angleB : angleA;
      const majorEnd = delta > 0 ? angleA : angleB;

      const s = normalizeAngle(majorStart);
      const e = normalizeAngle(majorEnd);
      const phi = normalizeAngle(angleC);

      const inMajor = s <= e ? phi >= s && phi <= e : phi >= s || phi <= e;

      if (!inMajor) {
        // Mirror angleC across the center (angleC + PI)
        angleC = normalizeAngle(angleC + Math.PI);
      }
    }

    function render() {
      ensurePointInMajorArc();
      const { p1, p2, p3 } = getPoints();
      const centralAngleDegrees = getAngleDegrees(p1, center, p2);
      const inscribedAngleDegrees = getAngleDegrees(p1, p3, p2);
      const centralLabelPosition = getAngleLabelPosition(p1, center, p2);
      const inscribedLabelPosition = getAngleLabelPosition(p1, p3, p2, 36);

      handleA.attr("cx", p1.x).attr("cy", p1.y);
      handleB.attr("cx", p2.x).attr("cy", p2.y);
      inscribedPoint.attr("cx", p3.x).attr("cy", p3.y);
      sector.attr("d", getTrianglePath(p1, center, p2));
      highlightedArc.attr(
        "d",
        getCircleArcPath(center, radius, angleA, angleB),
      );
      inscribedLines.attr("d", getInscribedLinesPath(p1, p2, p3));
      marker.attr("d", getAngleArcPath(p1, center, p2));
      inscribedMarker.attr("d", getAngleArcPath(p1, p3, p2));
      angleLabel
        .attr("x", centralLabelPosition.x)
        .attr("y", centralLabelPosition.y)
        .text(formatAngle(centralAngleDegrees));
      inscribedLabel
        .attr("x", inscribedLabelPosition.x)
        .attr("y", inscribedLabelPosition.y)
        .text(formatAngle(inscribedAngleDegrees));
      relationLabel.text(
        `${formatAngle(centralAngleDegrees)} = 2 x ${formatAngle(inscribedAngleDegrees)}`,
      );
    }

    function setDraggingState(isDragging: boolean) {
      const cursor = isDragging ? "grabbing" : "grab";

      handleA.style("cursor", cursor);
      handleB.style("cursor", cursor);
      inscribedPoint.style("cursor", cursor);
    }

    function getPointerAngle(x: number, y: number) {
      return Math.atan2(y - cy, x - cx);
    }

    const handleADragBehavior = d3
      .drag<SVGCircleElement, unknown>()
      .on("start", () => {
        setDraggingState(true);
      })
      .on("drag", (event) => {
        angleA = getPointerAngle(event.x, event.y);
        render();
      })
      .on("end", () => {
        setDraggingState(false);
      });

    const handleBDragBehavior = d3
      .drag<SVGCircleElement, unknown>()
      .on("start", () => {
        setDraggingState(true);
      })
      .on("drag", (event) => {
        angleB = getPointerAngle(event.x, event.y);
        render();
      })
      .on("end", () => {
        setDraggingState(false);
      });

    const handleCDragBehavior = d3
      .drag<SVGCircleElement, unknown>()
      .on("start", () => {
        setDraggingState(true);
      })
      .on("drag", (event) => {
        const newAngle = getPointerAngle(event.x, event.y);
        const delta = getSignedMinorDelta(angleA, angleB);

        // The green dot is restricted to the MAJOR arc (the one NOT highlighted).
        // If delta > 0, minor arc is A -> B CCW, so major arc is B -> A CCW.
        // If delta < 0, minor arc is B -> A CCW, so major arc is A -> B CCW.
        const majorStart = delta > 0 ? angleB : angleA;
        const majorEnd = delta > 0 ? angleA : angleB;

        const s = normalizeAngle(majorStart);
        const e = normalizeAngle(majorEnd);
        const phi = normalizeAngle(newAngle);

        const inMajor = s <= e ? phi >= s && phi <= e : phi >= s || phi <= e;

        if (inMajor) {
          angleC = newAngle;
        } else {
          const distS = Math.abs(getSignedMinorDelta(newAngle, majorStart));
          const distE = Math.abs(getSignedMinorDelta(newAngle, majorEnd));
          angleC = distS < distE ? majorStart : majorEnd;
        }
        render();
      })
      .on("end", () => {
        setDraggingState(false);
      });

    handleA.call(handleADragBehavior);
    handleB.call(handleBDragBehavior);
    inscribedPoint.call(handleCDragBehavior);
    render();
  }

  setupInteractivity();
  document.addEventListener("astro:after-swap", setupInteractivity);
</script>
