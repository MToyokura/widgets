---
const lowPowerControlId = Astro.props.lowPowerControlId ?? "";
const antialiasControlId = Astro.props.antialiasControlId ?? "";
---

<div class="viz-container" id="intersecting-lines-wrapper">
  <div
    class="threejs-viz"
    data-low-power-control-id={lowPowerControlId}
    data-antialias-control-id={antialiasControlId}
  ></div>
</div>

<style>
  .threejs-viz {
    width: 100%;
    aspect-ratio: 1 / 1;
    max-width: 720px;
    min-height: 320px;
    margin: 0 auto;
    border-radius: 8px;
    overflow: hidden;
    background: #e0e0e0;
  }
  .threejs-viz :global(canvas) {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  import * as THREE from "three";
import { OrbitControls } from "three/addons/controls/OrbitControls.js";
import { Line2 } from "three/addons/lines/Line2.js";
import { LineGeometry } from "three/addons/lines/LineGeometry.js";
import { LineMaterial } from "three/addons/lines/LineMaterial.js";
import {
createLowPowerRenderer,
disposeRenderer,
disposeSceneResources,
initializeThreeScene,
observeAntialiasPreference,
observeLowPowerPreference,
observeWrapperSize,
setRendererPerformanceMode,
} from "./functions/three";
  const wrapper = document.querySelector(
    "#intersecting-lines-wrapper .threejs-viz",
  );
  if (wrapper instanceof HTMLDivElement) {
    let sceneHandle: ReturnType<typeof initializeThreeScene> | undefined;

    const mountScene = () => {
      const lowPowerControlId = wrapper.dataset.lowPowerControlId || "";
      const antialiasControlId = wrapper.dataset.antialiasControlId || "";
      const scene = new THREE.Scene();
      scene.background = new THREE.Color(0xe0e0e0);
      const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100);
      camera.position.set(5, 4.5, 5);
      camera.lookAt(0, 0, 0);
      const renderer = createLowPowerRenderer(
        wrapper,
        lowPowerControlId,
        antialiasControlId,
      );
      const controls = new OrbitControls(camera, renderer.domElement);
      const resolution = new THREE.Vector2(1, 1);
      const plane = new THREE.Mesh(
        new THREE.PlaneGeometry(4.4, 4.4),
        new THREE.MeshBasicMaterial({
          color: 0xf8fafc,
          side: THREE.DoubleSide,
          transparent: true,
          opacity: 0.92,
        }),
      );
      plane.rotation.x = -Math.PI / 2;
      scene.add(plane);
      scene.add(new THREE.GridHelper(4.4, 8, 0x94a3b8, 0xcbd5e1));
      const l1 = [
        new THREE.Vector3(-1.8, 0, -0.6),
        new THREE.Vector3(1.8, 0, 0.6),
      ];
      const l2 = [
        new THREE.Vector3(-1.1, 0, 1.3),
        new THREE.Vector3(1.1, 0, -1.3),
      ];
      const g1 = new LineGeometry();
      g1.setPositions([l1[0].x, l1[0].y, l1[0].z, l1[1].x, l1[1].y, l1[1].z]);
      const g2 = new LineGeometry();
      g2.setPositions([l2[0].x, l2[0].y, l2[0].z, l2[1].x, l2[1].y, l2[1].z]);
      const line1 = new Line2(
        g1,
        new LineMaterial({ color: 0x111827, linewidth: 3, resolution }),
      );
      const line2 = new Line2(
        g2,
        new LineMaterial({ color: 0x2563eb, linewidth: 3, resolution }),
      );
      scene.add(line1);
      scene.add(line2);
      function resize(width: number, height: number) {
        camera.aspect = width / height;
        camera.updateProjectionMatrix();
        renderer.setSize(width, height, false);
        line1.material.resolution.set(width, height);
        line2.material.resolution.set(width, height);
        render();
      }
      function render() {
        renderer.render(scene, camera);
      }
      controls.addEventListener("change", render);
      const stopLowPowerObserver = observeLowPowerPreference(
        lowPowerControlId,
        (lowPower) => {
          setRendererPerformanceMode(renderer, lowPower);
          render();
        },
      );
      const stopAntialiasObserver = observeAntialiasPreference(
        antialiasControlId,
        () => {
          sceneHandle?.remount();
        },
      );
      const resizeObserver = observeWrapperSize(wrapper, resize);

      return () => {
        controls.dispose();
        stopLowPowerObserver?.();
        stopAntialiasObserver?.();
        resizeObserver.disconnect();
        disposeSceneResources(scene);
        disposeRenderer(renderer);
      };
    };

    sceneHandle = initializeThreeScene(wrapper, mountScene);
  }
</script>
