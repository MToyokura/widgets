---
import WidgetContainer from "../WidgetContainer.astro";

import {
  getCentroid,
  getCircleArcPath,
  getPointOnCircle,
  getPolygonPath,
  rotatePoint,
} from "./functions/geometry";

const width = 400;
const height = 400;
const guideRadius = 72;
const rotationCenter = { x: 210, y: 210 };
const rotationAngle = 0;
const originalPoints = [
  { x: 80, y: 270 },
  { x: 155, y: 130 },
  { x: 240, y: 230 },
];
const centroid = getCentroid(originalPoints);
const initialRotatedPoints = originalPoints.map((point) =>
  rotatePoint(point, rotationCenter, rotationAngle),
);
const initialAngleHandle = getPointOnCircle(
  rotationCenter,
  guideRadius,
  rotationAngle,
);
---

<WidgetContainer id="rotation-wrapper">
  <svg viewBox={`0 0 ${width} ${height}`}>
    {
      Array.from({ length: Math.floor(width / 40) + 1 }, (_, i) => i * 40).map(
        (x) => (
          <line
            x1={x}
            y1="0"
            x2={x}
            y2={height}
            stroke="#d7dde5"
            stroke-width="1"
          />
        ),
      )
    }
    {
      Array.from({ length: Math.floor(height / 40) + 1 }, (_, i) => i * 40).map(
        (y) => (
          <line
            x1="0"
            y1={y}
            x2={width}
            y2={y}
            stroke="#d7dde5"
            stroke-width="1"
          />
        ),
      )
    }
    <circle
      cx={rotationCenter.x}
      cy={rotationCenter.y}
      r={guideRadius}
      fill="none"
      stroke="#cbd5e1"
      stroke-width="2"
      stroke-dasharray="5 5"></circle>
    <path
      id="rotation-original-shape"
      d={getPolygonPath(originalPoints)}
      fill="rgba(37, 99, 235, 0.24)"
      stroke="#2563eb"
      stroke-width="3"></path>
    {
      originalPoints.map((point) => {
        const radius = Math.sqrt(
          Math.pow(point.x - rotationCenter.x, 2) +
            Math.pow(point.y - rotationCenter.y, 2),
        );
        const startAngle = Math.atan2(
          point.y - rotationCenter.y,
          point.x - rotationCenter.x,
        );
        return (
          <path
            class="vertex-path"
            d={getCircleArcPath(
              rotationCenter,
              radius,
              startAngle,
              startAngle + 0,
            )}
            fill="none"
            stroke="#94a3b8"
            stroke-width="1"
            stroke-dasharray="2 2"
          />
        );
      })
    }
    <path
      id="rotation-transformed-shape"
      d={getPolygonPath(initialRotatedPoints)}
      fill="rgba(14, 165, 233, 0.22)"
      stroke="#0ea5e9"
      stroke-width="3"></path>
    <circle cx={rotationCenter.x} cy={rotationCenter.y} r="4" fill="#dc2626"
    ></circle>
    <circle
      id="rotation-angle-handle"
      cx={initialAngleHandle.x}
      cy={initialAngleHandle.y}
      r="10"
      fill="#f97316"
      style="cursor: grab; touch-action: none;"></circle>
    <circle
      id="rotation-move-handle"
      cx={centroid.x}
      cy={centroid.y}
      r="8"
      fill="#2563eb"
      style="cursor: grab; touch-action: none;"></circle>
  </svg>
</WidgetContainer>

<script>
  import * as d3 from "d3";
  import {
    getCentroid,
    getCircleArcPath,
    getPointOnCircle,
    getPolygonPath,
    rotatePoint,
  } from "./functions/geometry";

  function setupInteractivity() {
    const originalShape = d3.select<SVGPathElement, unknown>(
      "#rotation-original-shape",
    );
    const transformedShape = d3.select<SVGPathElement, unknown>(
      "#rotation-transformed-shape",
    );
    const angleHandle = d3.select<SVGCircleElement, unknown>(
      "#rotation-angle-handle",
    );
    const moveHandle = d3.select<SVGCircleElement, unknown>(
      "#rotation-move-handle",
    );

    let originalPoints = [
      { x: 80, y: 270 },
      { x: 155, y: 130 },
      { x: 240, y: 230 },
    ];
    let centroid = getCentroid(originalPoints);

    const rotationCenter = { x: 210, y: 210 };
    const guideRadius = 72;
    let rotationAngle = 0;

    function render() {
      const rotatedPoints = originalPoints.map((point) =>
        rotatePoint(point, rotationCenter, rotationAngle),
      );
      const nextAngleHandle = getPointOnCircle(
        rotationCenter,
        guideRadius,
        rotationAngle,
      );

      originalShape.attr("d", getPolygonPath(originalPoints));
      transformedShape.attr("d", getPolygonPath(rotatedPoints));
      moveHandle.attr("cx", centroid.x).attr("cy", centroid.y);
      angleHandle.attr("cx", nextAngleHandle.x).attr("cy", nextAngleHandle.y);

      d3.selectAll(".vertex-path")
        .data(originalPoints)
        .attr("d", (d: any) => {
          const radius = Math.sqrt(
            Math.pow(d.x - rotationCenter.x, 2) +
              Math.pow(d.y - rotationCenter.y, 2),
          );
          const startAngle = Math.atan2(
            d.y - rotationCenter.y,
            d.x - rotationCenter.x,
          );
          return getCircleArcPath(
            rotationCenter,
            radius,
            startAngle,
            startAngle + rotationAngle,
          );
        });
    }

    render();

    angleHandle.call(
      d3.drag<SVGCircleElement, unknown>().on("drag", (event) => {
        rotationAngle = Math.atan2(
          event.y - rotationCenter.y,
          event.x - rotationCenter.x,
        );
        render();
      }),
    );

    moveHandle.call(
      d3.drag<SVGCircleElement, unknown>().on("drag", (event) => {
        const dx = event.x - centroid.x;
        const dy = event.y - centroid.y;
        originalPoints = originalPoints.map((p) => ({
          x: p.x + dx,
          y: p.y + dy,
        }));
        centroid = { x: event.x, y: event.y };
        render();
      }),
    );
  }

  setupInteractivity();
  document.addEventListener("astro:after-swap", setupInteractivity);
</script>
