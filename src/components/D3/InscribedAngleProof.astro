---
import WidgetContainer from "../WidgetContainer.astro";

import {
  getAngleArcPath,
  getAngleDegrees,
  getCircleArcPath,
  getAngleLabelPosition,
  getPointOnCircle,
  getTrianglePath,
} from "./functions/geometry";

const width = 400;
const height = 400;
const radius = 150;
const cx = width / 2;
const cy = height / 2;
const center = { x: cx, y: cy };
const degenerateAngleThresholdDegrees = 0.5;
const initialAngleA = (3 * Math.PI) / 4;
const initialAngleB = Math.PI / 4;
const initialAngleC = -Math.PI / 2;

const p1 = getPointOnCircle(center, radius, initialAngleA);
const p2 = getPointOnCircle(center, radius, initialAngleB);
const p3 = getPointOnCircle(center, radius, initialAngleC);

function getOppositePoint(point: { x: number; y: number }) {
  return {
    x: cx - (point.x - cx),
    y: cy - (point.y - cy),
  };
}

function getLinePath(
  start: { x: number; y: number },
  end: { x: number; y: number },
) {
  return `M ${start.x} ${start.y} L ${end.x} ${end.y}`;
}

function getPointLabelPosition(point: { x: number; y: number }) {
  const dx = point.x - cx;
  const dy = point.y - cy;
  const length = Math.hypot(dx, dy) || 1;
  const offset = 24;

  return {
    x: point.x + (dx / length) * offset,
    y: point.y + (dy / length) * offset,
  };
}

function getVisibilityStyle(isVisible: boolean) {
  return isVisible
    ? "pointer-events: none;"
    : "pointer-events: none; display: none;";
}

function getDoubleAngleDotPositions(
  a: { x: number; y: number },
  vertex: { x: number; y: number },
  b: { x: number; y: number },
  distanceFromVertex = 22,
  spacing = 10,
  dotRadius = 4,
) {
  const midpoint = getAngleLabelPosition(a, vertex, b, distanceFromVertex);
  const dx = midpoint.x - vertex.x;
  const dy = midpoint.y - vertex.y;
  const midpointDistance = Math.hypot(dx, dy);
  const directionLength = midpointDistance || 1;
  const angleRadians = (getAngleDegrees(a, vertex, b) * Math.PI) / 180;
  const availableWidth = midpointDistance * 2 * Math.sin(angleRadians / 2);
  const minimumSpacing = Math.min(spacing, Math.max(3, dotRadius * 0.5));
  const effectiveSpacing = Math.max(
    minimumSpacing,
    Math.min(spacing, availableWidth - dotRadius * 2),
  );
  const offsetX = (-dy / directionLength) * (effectiveSpacing / 2);
  const offsetY = (dx / directionLength) * (effectiveSpacing / 2);

  return [
    { x: midpoint.x + offsetX, y: midpoint.y + offsetY },
    { x: midpoint.x - offsetX, y: midpoint.y - offsetY },
  ];
}

const insetAngleIndicatorCenter = { x: width - 54, y: height - 54 };
const insetAngleIndicatorRadius = 30;
const insetAngleIndicatorRayRadius = insetAngleIndicatorRadius;
const insetAngleIndicatorArcRadius = insetAngleIndicatorRadius;
const insetAngleIndicatorLayoutRadius = 34;
const insetAngleIndicatorDotSpacing = 6;
const insetAngleIndicatorDotGroupOffset = insetAngleIndicatorLayoutRadius * 0.5;

function getInsetAngleIndicatorPaths(
  angleDegrees: number,
  side: "left" | "right",
) {
  const angleRadians = Math.max(
    0,
    Math.min(Math.PI, (angleDegrees * Math.PI) / 180),
  );
  const splitTop = {
    x: insetAngleIndicatorCenter.x,
    y: insetAngleIndicatorCenter.y - insetAngleIndicatorRadius,
  };
  const splitBottom = {
    x: insetAngleIndicatorCenter.x,
    y: insetAngleIndicatorCenter.y + insetAngleIndicatorRadius,
  };
  const sectorStart = getPointOnCircle(
    insetAngleIndicatorCenter,
    insetAngleIndicatorRayRadius,
    Math.PI / 2,
  );
  const endAngle =
    side === "left" ? Math.PI / 2 + angleRadians : Math.PI / 2 - angleRadians;
  const sectorEnd = getPointOnCircle(
    insetAngleIndicatorCenter,
    insetAngleIndicatorRayRadius,
    endAngle,
  );
  const hasVisibleAngle = angleRadians > 0.01;
  const sweepFlag = side === "left" ? 1 : 0;
  const dotBaseX =
    insetAngleIndicatorCenter.x +
    (side === "left"
      ? -insetAngleIndicatorDotGroupOffset
      : insetAngleIndicatorDotGroupOffset);
  const dotY = insetAngleIndicatorCenter.y + insetAngleIndicatorLayoutRadius;

  return {
    splitPath: getLinePath(splitTop, splitBottom),
    sectorPath: hasVisibleAngle
      ? `M ${insetAngleIndicatorCenter.x} ${insetAngleIndicatorCenter.y} L ${sectorStart.x} ${sectorStart.y} A ${insetAngleIndicatorRayRadius} ${insetAngleIndicatorRayRadius} 0 0 ${sweepFlag} ${sectorEnd.x} ${sectorEnd.y} Z`
      : "",
    rayPath: hasVisibleAngle
      ? getLinePath(insetAngleIndicatorCenter, sectorEnd)
      : "",
    arcPath: hasVisibleAngle
      ? getCircleArcPath(
          insetAngleIndicatorCenter,
          insetAngleIndicatorArcRadius,
          Math.PI / 2,
          endAngle,
        )
      : "",
    dotPositions: [
      { x: dotBaseX - insetAngleIndicatorDotSpacing / 2, y: dotY },
      { x: dotBaseX + insetAngleIndicatorDotSpacing / 2, y: dotY },
    ],
  };
}

const p4 = getOppositePoint(p3);
const initialAodInsetAngleIndicator = getInsetAngleIndicatorPaths(getAngleDegrees(p1, center, p4), "left");
const initialBodInsetAngleIndicator = getInsetAngleIndicatorPaths(getAngleDegrees(p2, center, p4), "right");
const initialShowAcoGroup = getAngleDegrees(p1, p3, p4) > degenerateAngleThresholdDegrees;
const initialShowBcoGroup = getAngleDegrees(p2, p3, p4) > degenerateAngleThresholdDegrees;

const initialAodDotPositions = getDoubleAngleDotPositions(p1, center, p4);
const initialBodDotPositions = getDoubleAngleDotPositions(p2, center, p4);

// UI Config Variables & Groupings for Refactored Rendering
const idBase = "inscribed-angle-proof-case-center-outside-triangle";

const indicatorGroups = [
  {
    idPrefix: "angle-aod",
    data: initialAodInsetAngleIndicator,
    sectorFill: "rgba(250, 204, 21, 0.18)",
    rayStroke: "#ca8a04",
    arcStroke: "#facc15",
    dotFill: "#facc15"
  },
  {
    idPrefix: "angle-bod",
    data: initialBodInsetAngleIndicator,
    sectorFill: "rgba(22, 163, 74, 0.16)",
    rayStroke: "#15803d",
    arcStroke: "#16a34a",
    dotFill: "#16a34a"
  }
];

const triangles = [
  { id: "aco-shape", path: getTrianglePath(p1, p3, center), fill: "rgba(250, 204, 21, 0.28)", stroke: "#ca8a04", show: initialShowAcoGroup },
  { id: "bco-shape", path: getTrianglePath(p2, p3, center), fill: "rgba(22, 163, 74, 0.2)", stroke: "#15803d", show: initialShowBcoGroup },
];

const bigArcs = [
  { id: "angle-aod-arc", path: getAngleArcPath(p1, center, p4, 38), stroke: "#facc15", show: initialShowAcoGroup },
  { id: "angle-bod-arc", path: getAngleArcPath(p2, center, p4, 30), stroke: "#16a34a", show: initialShowBcoGroup },
];

const dots = [
  { id: "angle-aco-dot", pos: getAngleLabelPosition(p1, p3, center, 18), show: initialShowAcoGroup, fill: "#facc15" },
  { id: "angle-cao-dot", pos: getAngleLabelPosition(p3, p1, center, 18), show: initialShowAcoGroup, fill: "#facc15" },
  { id: "angle-aod-dot-1", pos: initialAodDotPositions[0], show: initialShowAcoGroup, fill: "#facc15" },
  { id: "angle-aod-dot-2", pos: initialAodDotPositions[1], show: initialShowAcoGroup, fill: "#facc15" },
  { id: "angle-bco-dot", pos: getAngleLabelPosition(p2, p3, center, 18), show: initialShowBcoGroup, fill: "#16a34a" },
  { id: "angle-cbo-dot", pos: getAngleLabelPosition(p3, p2, center, 18), show: initialShowBcoGroup, fill: "#16a34a" },
  { id: "angle-bod-dot-1", pos: initialBodDotPositions[0], show: initialShowBcoGroup, fill: "#16a34a" },
  { id: "angle-bod-dot-2", pos: initialBodDotPositions[1], show: initialShowBcoGroup, fill: "#16a34a" },
];

const handles = [
  { id: "handle-a", pos: p1, fill: "#2563eb" },
  { id: "handle-b", pos: p2, fill: "#2563eb" },
  { id: "handle-c", pos: p3, fill: "#e74c3c" },
];

const labels = [
  { id: "point-a-label", text: "A", pos: getPointLabelPosition(p1) },
  { id: "point-b-label", text: "B", pos: getPointLabelPosition(p2) },
  { id: "point-c-label", text: "C", pos: getPointLabelPosition(p3) },
  { id: "point-d-label", text: "D", pos: getPointLabelPosition(p4) },
];
---

<WidgetContainer
  id={`${idBase}-wrapper`}
  data-degenerate-angle-threshold={degenerateAngleThresholdDegrees}
  data-initial-angle-a={initialAngleA}
  data-initial-angle-b={initialAngleB}
  data-initial-angle-c={initialAngleC}
>
  <svg viewBox={`0 0 ${width} ${height}`}>
    <circle cx={cx} cy={cy} r={radius} fill="none" stroke="#888" stroke-width="2"></circle>
    
    <path
      id={`${idBase}-diameter`}
      d={getLinePath(p3, p4)}
      fill="none"
      stroke="#4b5563"
      stroke-width="2.5"
      stroke-dasharray="6 5"
      stroke-linecap="round"
      style="pointer-events: none;"
    ></path>

    <g style="pointer-events: none;">
      <circle cx={insetAngleIndicatorCenter.x} cy={insetAngleIndicatorCenter.y} r={insetAngleIndicatorRadius} fill="white" stroke="#9ca3af" stroke-width="2"></circle>
      <path d={initialAodInsetAngleIndicator.splitPath} fill="none" stroke="#9ca3af" stroke-width="2"></path>
      
      {indicatorGroups.map(group => (
        <g>
          <path id={`${idBase}-${group.idPrefix}-indicator-sector`} d={group.data.sectorPath} fill={group.sectorFill} stroke="none"></path>
          <path id={`${idBase}-${group.idPrefix}-indicator-ray`} d={group.data.rayPath} fill="none" stroke={group.rayStroke} stroke-width="2.5" stroke-linecap="round"></path>
          <path id={`${idBase}-${group.idPrefix}-indicator-arc`} d={group.data.arcPath} fill="none" stroke={group.arcStroke} stroke-width="4" stroke-linecap="round"></path>
          <circle id={`${idBase}-${group.idPrefix}-indicator-dot-1`} cx={group.data.dotPositions[0].x} cy={group.data.dotPositions[0].y} r={3.5} fill={group.dotFill} stroke="#111827" stroke-width="1.5"></circle>
          <circle id={`${idBase}-${group.idPrefix}-indicator-dot-2`} cx={group.data.dotPositions[1].x} cy={group.data.dotPositions[1].y} r={3.5} fill={group.dotFill} stroke="#111827" stroke-width="1.5"></circle>
        </g>
      ))}
    </g>

    {triangles.map(shape => (
      <path
        id={`${idBase}-${shape.id}`}
        d={shape.path}
        fill={shape.fill}
        stroke={shape.stroke}
        stroke-width="2"
        style={getVisibilityStyle(shape.show)}
      ></path>
    ))}

    {bigArcs.map(arc => (
      <path
        id={`${idBase}-${arc.id}`}
        d={arc.path}
        fill="none"
        stroke={arc.stroke}
        stroke-width="5"
        stroke-linecap="round"
        style={getVisibilityStyle(arc.show)}
      ></path>
    ))}

    {dots.map(dot => (
      <circle
        id={`${idBase}-${dot.id}`}
        cx={dot.pos.x}
        cy={dot.pos.y}
        r={4}
        fill={dot.fill}
        stroke="#111827"
        stroke-width="1.5"
        style={getVisibilityStyle(dot.show)}
      ></circle>
    ))}

    <circle cx={cx} cy={cy} r={5} fill="#111827" style="pointer-events: none;"></circle>
    
    <text x={cx + 16} y={cy - 14} fill="#111827" font-size="18" font-weight="700" text-anchor="middle" dominant-baseline="middle" style="pointer-events: none; user-select: none;">
      O
    </text>

    {handles.map(handle => (
      <circle
        id={`${idBase}-${handle.id}`}
        cx={handle.pos.x}
        cy={handle.pos.y}
        r={10}
        fill={handle.fill}
        style="cursor: grab; touch-action: none;"
      ></circle>
    ))}

    <circle id={`${idBase}-point-d`} cx={p4.x} cy={p4.y} r={6} fill="#111827" style="pointer-events: none;"></circle>

    {labels.map(label => (
      <text
        id={`${idBase}-${label.id}`}
        x={label.pos.x}
        y={label.pos.y}
        fill="#111827"
        font-size="18"
        font-weight="700"
        text-anchor="middle"
        dominant-baseline="middle"
        style="pointer-events: none; user-select: none;"
      >
        {label.text}
      </text>
    ))}
  </svg>
</WidgetContainer>

<script>
  import * as d3 from "d3";
import {
getAngleArcPath,
getAngleDegrees,
getAngleLabelPosition,
getCircleArcPath,
getPointOnCircle,
getTrianglePath,
} from "./functions/geometry";

  function getOppositePoint(point: { x: number; y: number }) {
    return { x: 200 - (point.x - 200), y: 200 - (point.y - 200) };
  }

  function getLinePath(start: { x: number; y: number }, end: { x: number; y: number }) {
    return `M ${start.x} ${start.y} L ${end.x} ${end.y}`;
  }

  function getPointLabelPosition(point: { x: number; y: number }) {
    const dx = point.x - 200;
    const dy = point.y - 200;
    const length = Math.hypot(dx, dy) || 1;
    return { x: point.x + (dx / length) * 24, y: point.y + (dy / length) * 24 };
  }

  function getDoubleAngleDotPositions(
    a: { x: number; y: number },
    vertex: { x: number; y: number },
    b: { x: number; y: number },
    distanceFromVertex = 22,
    spacing = 10,
    dotRadius = 4,
  ) {
    const midpoint = getAngleLabelPosition(a, vertex, b, distanceFromVertex);
    const dx = midpoint.x - vertex.x;
    const dy = midpoint.y - vertex.y;
    const midpointDistance = Math.hypot(dx, dy);
    const directionLength = midpointDistance || 1;
    const angleRadians = (getAngleDegrees(a, vertex, b) * Math.PI) / 180;
    const availableWidth = midpointDistance * 2 * Math.sin(angleRadians / 2);
    const minimumSpacing = Math.min(spacing, Math.max(3, dotRadius * 0.5));
    const effectiveSpacing = Math.max(minimumSpacing, Math.min(spacing, availableWidth - dotRadius * 2));
    const offsetX = (-dy / directionLength) * (effectiveSpacing / 2);
    const offsetY = (dx / directionLength) * (effectiveSpacing / 2);

    return [
      { x: midpoint.x + offsetX, y: midpoint.y + offsetY },
      { x: midpoint.x - offsetX, y: midpoint.y - offsetY },
    ];
  }

  const insetAngleIndicatorCenter = { x: 400 - 54, y: 400 - 54 };
  const insetAngleIndicatorRadius = 30;

  function getInsetAngleIndicatorPaths(angleDegrees: number, side: "left" | "right") {
    const angleRadians = Math.max(0, Math.min(Math.PI, (angleDegrees * Math.PI) / 180));
    const sectorStart = getPointOnCircle(insetAngleIndicatorCenter, insetAngleIndicatorRadius, Math.PI / 2);
    const endAngle = side === "left" ? Math.PI / 2 + angleRadians : Math.PI / 2 - angleRadians;
    const sectorEnd = getPointOnCircle(insetAngleIndicatorCenter, insetAngleIndicatorRadius, endAngle);
    const hasVisibleAngle = angleRadians > 0.01;
    const sweepFlag = side === "left" ? 1 : 0;
    const dotBaseX = insetAngleIndicatorCenter.x + (side === "left" ? -17 : 17);
    const dotY = insetAngleIndicatorCenter.y + 34;

    return {
      sectorPath: hasVisibleAngle ? `M ${insetAngleIndicatorCenter.x} ${insetAngleIndicatorCenter.y} L ${sectorStart.x} ${sectorStart.y} A ${insetAngleIndicatorRadius} ${insetAngleIndicatorRadius} 0 0 ${sweepFlag} ${sectorEnd.x} ${sectorEnd.y} Z` : "",
      rayPath: hasVisibleAngle ? getLinePath(insetAngleIndicatorCenter, sectorEnd) : "",
      arcPath: hasVisibleAngle ? getCircleArcPath(insetAngleIndicatorCenter, insetAngleIndicatorRadius, Math.PI / 2, endAngle) : "",
      dotPositions: [ { x: dotBaseX - 3, y: dotY }, { x: dotBaseX + 3, y: dotY } ],
    };
  }

  function setupInteractivity() {
    const idBase = "inscribed-angle-proof-case-center-outside-triangle";
    const wrapper = document.getElementById(`${idBase}-wrapper`);
    if (!wrapper) return;

    // D3 DOM Helpers
    const $ = <T extends d3.BaseType = HTMLElement>(id: string) => d3.select<T, unknown>(`#${idBase}-${id}`);
    const setPos = (id: string, pos: { x: number; y: number }) => $<SVGCircleElement>(id).attr("cx", pos.x).attr("cy", pos.y);
    const setText = (id: string, pos: { x: number; y: number }) => $<SVGTextElement>(id).attr("x", pos.x).attr("y", pos.y);
    const setPath = (id: string, d: string) => $<SVGPathElement>(id).attr("d", d);
    const setVis = (id: string, show: boolean) => $<SVGElement>(id).style("display", show ? "" : "none");

    const cx = 200;
    const cy = 200;
    const radius = 150;
    const center = { x: cx, y: cy };

    const parseNum = (val: string | undefined, fallback: number) => Number.isFinite(Number(val)) ? Number(val) : fallback;
    const degenerateAngleThresholdDegrees = parseNum(wrapper.dataset.degenerateAngleThreshold, 0.5);
    let angleA = parseNum(wrapper.dataset.initialAngleA, (3 * Math.PI) / 4);
    let angleB = parseNum(wrapper.dataset.initialAngleB, Math.PI / 4);
    let angleC = parseNum(wrapper.dataset.initialAngleC, -Math.PI / 2);

    function render() {
      const p1 = getPointOnCircle(center, radius, angleA);
      const p2 = getPointOnCircle(center, radius, angleB);
      const p3 = getPointOnCircle(center, radius, angleC);
      const p4 = getOppositePoint(p3);

      const showAcoGroup = getAngleDegrees(p1, p3, p4) > degenerateAngleThresholdDegrees;
      const showBcoGroup = getAngleDegrees(p2, p3, p4) > degenerateAngleThresholdDegrees;
      const aodIndicator = getInsetAngleIndicatorPaths(getAngleDegrees(p1, center, p4), "left");
      const bodIndicator = getInsetAngleIndicatorPaths(getAngleDegrees(p2, center, p4), "right");
      const aodDots = getDoubleAngleDotPositions(p1, center, p4);
      const bodDots = getDoubleAngleDotPositions(p2, center, p4);

      // Points & Labels
      setPos("handle-a", p1); setText("point-a-label", getPointLabelPosition(p1));
      setPos("handle-b", p2); setText("point-b-label", getPointLabelPosition(p2));
      setPos("handle-c", p3); setText("point-c-label", getPointLabelPosition(p3));
      setPos("point-d", p4); setText("point-d-label", getPointLabelPosition(p4));

      // Shapes & Paths
      setPath("diameter", getLinePath(p3, p4));
      setPath("aco-shape", getTrianglePath(p1, p3, center)); setVis("aco-shape", showAcoGroup);
      setPath("bco-shape", getTrianglePath(p2, p3, center)); setVis("bco-shape", showBcoGroup);
      
      setPath("angle-aod-arc", getAngleArcPath(p1, center, p4, 38)); setVis("angle-aod-arc", showAcoGroup);
      setPath("angle-bod-arc", getAngleArcPath(p2, center, p4, 30)); setVis("angle-bod-arc", showBcoGroup);

      // Dots Visibilities & Position
      setPos("angle-aco-dot", getAngleLabelPosition(p1, p3, center, 18)); setVis("angle-aco-dot", showAcoGroup);
      setPos("angle-cao-dot", getAngleLabelPosition(p3, p1, center, 18)); setVis("angle-cao-dot", showAcoGroup);
      setPos("angle-aod-dot-1", aodDots[0]); setVis("angle-aod-dot-1", showAcoGroup);
      setPos("angle-aod-dot-2", aodDots[1]); setVis("angle-aod-dot-2", showAcoGroup);

      setPos("angle-bco-dot", getAngleLabelPosition(p2, p3, center, 18)); setVis("angle-bco-dot", showBcoGroup);
      setPos("angle-cbo-dot", getAngleLabelPosition(p3, p2, center, 18)); setVis("angle-cbo-dot", showBcoGroup);
      setPos("angle-bod-dot-1", bodDots[0]); setVis("angle-bod-dot-1", showBcoGroup);
      setPos("angle-bod-dot-2", bodDots[1]); setVis("angle-bod-dot-2", showBcoGroup);

      // Indicator Groups
      setPath("angle-aod-indicator-sector", aodIndicator.sectorPath);
      setPath("angle-aod-indicator-ray", aodIndicator.rayPath);
      setPath("angle-aod-indicator-arc", aodIndicator.arcPath);
      setPos("angle-aod-indicator-dot-1", aodIndicator.dotPositions[0]);
      setPos("angle-aod-indicator-dot-2", aodIndicator.dotPositions[1]);

      setPath("angle-bod-indicator-sector", bodIndicator.sectorPath);
      setPath("angle-bod-indicator-ray", bodIndicator.rayPath);
      setPath("angle-bod-indicator-arc", bodIndicator.arcPath);
      setPos("angle-bod-indicator-dot-1", bodIndicator.dotPositions[0]);
      setPos("angle-bod-indicator-dot-2", bodIndicator.dotPositions[1]);
    }

    const setDraggingState = (isDragging: boolean) => {
      const cursor = isDragging ? "grabbing" : "grab";
      $("handle-a").style("cursor", cursor);
      $("handle-b").style("cursor", cursor);
      $("handle-c").style("cursor", cursor);
    };

    const createDragBehavior = (setAngle: (angle: number) => void) =>
      d3.drag<SVGCircleElement, unknown>()
        .on("start", () => setDraggingState(true))
        .on("drag", (event) => {
          setAngle(Math.atan2(event.y - cy, event.x - cx));
          render();
        })
        .on("end", () => setDraggingState(false));

    $<SVGCircleElement>("handle-a").call(createDragBehavior((a) => (angleA = a)));
    $<SVGCircleElement>("handle-b").call(createDragBehavior((a) => (angleB = a)));
    $<SVGCircleElement>("handle-c").call(createDragBehavior((a) => (angleC = a)));
    
    render();
  }

  setupInteractivity();
  document.addEventListener("astro:after-swap", setupInteractivity);
</script>