---
const {
  id,
  label,
  description = "",
  min = 0,
  max = 1,
  step = 0.1,
  value = 0,
  valuePrefix = "",
  valueSuffix = "",
} = Astro.props;
---

<div class="scene-range-control" data-scene-range-control>
  <label class="scene-range-control__label" for={id}>{label}</label>
  <input
    id={id}
    class="scene-range-control__input"
    type="range"
    min={min}
    max={max}
    step={step}
    value={value}
    data-value-prefix={valuePrefix}
    data-value-suffix={valueSuffix}
  />
  {description && <p class="scene-range-control__description">{description}</p>}
</div>

<style>
  .scene-range-control {
    margin: 1.5rem 0;
    padding: 0;
    border: none;
    border-radius: 0;
    background: transparent;
  }

  .scene-range-control__label {
    display: block;
    font-weight: 600;
    color: var(--sl-color-text);
    margin-bottom: 0.5rem;
  }

  .scene-range-control__input {
    width: 100%;
    margin: 0;
  }

  .scene-range-control__description {
    margin: 0.5rem 0 0;
    font-size: 0.95rem;
    color: var(--sl-color-text);
  }
</style>

<script>
  for (const root of document.querySelectorAll("[data-scene-range-control]")) {
    if (!(root instanceof HTMLDivElement) || root.dataset.ready === "true") {
      continue;
    }

    root.dataset.ready = "true";
  }
</script>
