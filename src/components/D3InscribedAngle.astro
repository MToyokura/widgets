---
import {
  getAngleArcPath,
  getAngleDegrees,
  getAngleLabelPosition,
  getPointOnCircle,
  getTrianglePath,
} from "./d3-geometry";

const width = 400;
const height = 400;
const radius = 150;
const cx = width / 2;
const cy = height / 2;
const center = { x: cx, y: cy };

const p1 = getPointOnCircle(center, radius, (7 * Math.PI) / 6);
const p2 = getPointOnCircle(center, radius, -Math.PI / 6);
const p3 = getPointOnCircle(center, radius, -Math.PI / 2);
const initialPath = getTrianglePath(p1, p2, p3);
const initialAngleArcPath = getAngleArcPath(p1, p3, p2);
const initialAngleLabelPosition = getAngleLabelPosition(p1, p3, p2);
const initialAngleDegrees = getAngleDegrees(p1, p3, p2);
---

<div class="viz-container" id="inscribed-angle-wrapper">
  <svg viewBox={`0 0 ${width} ${height}`} style="display: block; margin: auto;">
    <circle
      cx={cx}
      cy={cy}
      r={radius}
      fill="none"
      stroke="#888"
      stroke-width="2"></circle>
    <path
      id="inscribed-angle-triangle"
      d={initialPath}
      fill="rgba(52, 152, 219, 0.3)"
      stroke="#3498db"
      stroke-width="3"
      style="pointer-events: none;"></path>
    <path
      id="inscribed-angle-marker"
      d={initialAngleArcPath}
      fill="none"
      stroke="#1f2937"
      stroke-width="3"
      stroke-linecap="round"
      style="pointer-events: none;"></path>
    <text
      id="inscribed-angle-label"
      x={initialAngleLabelPosition.x}
      y={initialAngleLabelPosition.y}
      fill="#111827"
      font-size="16"
      font-weight="700"
      text-anchor="middle"
      dominant-baseline="middle"
      style="pointer-events: none; user-select: none;"
    >
      {`${Math.round(initialAngleDegrees)}°`}
    </text>
    <circle
      id="inscribed-angle-handle-a"
      cx={p1.x}
      cy={p1.y}
      r={10}
      fill="#2563eb"
      style="cursor: grab; touch-action: none;"></circle>
    <circle
      id="inscribed-angle-handle-b"
      cx={p2.x}
      cy={p2.y}
      r={10}
      fill="#2563eb"
      style="cursor: grab; touch-action: none;"></circle>
    <circle
      id="inscribed-angle-handle-c"
      cx={p3.x}
      cy={p3.y}
      r={10}
      fill="#e74c3c"
      style="cursor: grab; touch-action: none;"></circle>
  </svg>
</div>

<script>
  import * as d3 from "d3";
  import {
    getAngleArcPath,
    getAngleDegrees,
    getAngleLabelPosition,
    getPointOnCircle,
    getTrianglePath,
  } from "./d3-geometry";

  function setupInteractivity() {
    const handleA = d3.select<SVGCircleElement, unknown>(
      "#inscribed-angle-handle-a",
    );
    const handleB = d3.select<SVGCircleElement, unknown>(
      "#inscribed-angle-handle-b",
    );
    const handleC = d3.select<SVGCircleElement, unknown>(
      "#inscribed-angle-handle-c",
    );
    const triangle = d3.select<SVGPathElement, unknown>(
      "#inscribed-angle-triangle",
    );
    const marker = d3.select<SVGPathElement, unknown>(
      "#inscribed-angle-marker",
    );
    const angleLabel = d3.select<SVGTextElement, unknown>(
      "#inscribed-angle-label",
    );

    if (
      handleA.empty() ||
      handleB.empty() ||
      handleC.empty() ||
      triangle.empty() ||
      marker.empty() ||
      angleLabel.empty()
    ) {
      return;
    }

    const cx = 200;
    const cy = 200;
    const radius = 150;
    const center = { x: cx, y: cy };
    let angleA = (7 * Math.PI) / 6;
    let angleB = -Math.PI / 6;
    let angleC = -Math.PI / 2;

    function getPoints() {
      return {
        p1: getPointOnCircle(center, radius, angleA),
        p2: getPointOnCircle(center, radius, angleB),
        p3: getPointOnCircle(center, radius, angleC),
      };
    }

    function formatAngle(angleDegrees: number) {
      const roundedAngle = Math.round(angleDegrees * 10) / 10;

      return Number.isInteger(roundedAngle)
        ? `${roundedAngle.toFixed(0)}°`
        : `${roundedAngle.toFixed(1)}°`;
    }

    function render() {
      const { p1, p2, p3 } = getPoints();
      const angleDegrees = getAngleDegrees(p1, p3, p2);
      const labelPosition = getAngleLabelPosition(p1, p3, p2);

      handleA.attr("cx", p1.x).attr("cy", p1.y);
      handleB.attr("cx", p2.x).attr("cy", p2.y);
      handleC.attr("cx", p3.x).attr("cy", p3.y);
      triangle.attr("d", getTrianglePath(p1, p2, p3));
      marker.attr("d", getAngleArcPath(p1, p3, p2));
      angleLabel
        .attr("x", labelPosition.x)
        .attr("y", labelPosition.y)
        .text(formatAngle(angleDegrees));
    }

    function setDraggingState(isDragging: boolean) {
      const cursor = isDragging ? "grabbing" : "grab";

      handleA.style("cursor", cursor);
      handleB.style("cursor", cursor);
      handleC.style("cursor", cursor);
    }

    function getPointerAngle(x: number, y: number) {
      return Math.atan2(y - cy, x - cx);
    }

    const handleADragBehavior = d3
      .drag<SVGCircleElement, unknown>()
      .on("start", () => {
        setDraggingState(true);
      })
      .on("drag", (event) => {
        angleA = getPointerAngle(event.x, event.y);
        render();
      })
      .on("end", () => {
        setDraggingState(false);
      });

    const handleBDragBehavior = d3
      .drag<SVGCircleElement, unknown>()
      .on("start", () => {
        setDraggingState(true);
      })
      .on("drag", (event) => {
        angleB = getPointerAngle(event.x, event.y);
        render();
      })
      .on("end", () => {
        setDraggingState(false);
      });

    const handleCDragBehavior = d3
      .drag<SVGCircleElement, unknown>()
      .on("start", () => {
        setDraggingState(true);
      })
      .on("drag", (event) => {
        angleC = getPointerAngle(event.x, event.y);
        render();
      })
      .on("end", () => {
        setDraggingState(false);
      });

    handleA.call(handleADragBehavior);
    handleB.call(handleBDragBehavior);
    handleC.call(handleCDragBehavior);
    render();
  }

  setupInteractivity();
  document.addEventListener("astro:after-swap", setupInteractivity);
</script>
